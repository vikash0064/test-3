    <a href="/logout" class="nav-item" style="color: #ed4956;">
        <svg viewBox="0 0 24 24">
            <path
                d="M10 2v2H5v16h5v2H3V2h7zm10.59 9l-4.29-4.3-1.42 1.42L17.17 11H8v2h9.17l-2.3 2.3 1.42 1.42 4.3-4.3-.01-.02.01-.02z"
                fill="currentColor"></path>
        </svg>
        <span>Logout</span>
    </a>
</div>