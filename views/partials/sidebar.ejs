    </a>

    <a href="/settings" class="nav-item">
        <svg viewBox="0 0 24 24">
            <path
                d="M19.336 10.1c.143.593.214 1.205.214 1.83a8.5 8.5 0 01-14.788 5.636 1 1 0 10-1.3 1.514A10.5 10.5 0 1021.55 11.93c0-.853-.087-1.686-.253-2.492a1 1 0 00-1.96.662zM12 7.5a4.5 4.5 0 11-4.5 4.5 4.5 4.5 0 014.5-4.5zm0 7a2.5 2.5 0 10-2.5-2.5 2.5 2.5 0 002.5 2.5z"
                fill="currentColor"></path>
        </svg>
        <span>Settings</span>
    </a>

    <div class="nav-item theme-toggle" onclick="toggleTheme()" style="cursor: pointer; margin-top: auto;">
        <svg id="sidebarThemeIconMoon" class="theme-icon-moon" viewBox="0 0 24 24">
            <path
                d="M21 12.75l-1.5 1.5-1.5-1.5M10.5 6A7.5 7.5 0 0018 13.5a7.512 7.512 0 004.14-1.233A9 9 0 1111.233 2.14 7.513 7.513 0 0010.5 6z"
                fill="currentColor"></path>
        </svg>
        <svg id="sidebarThemeIconSun" class="theme-icon-sun" viewBox="0 0 24 24">
            <path
                d="M12 7a5 5 0 105 5 5 5 0 00-5-5zm0 8a3 3 0 113-3 3 3 0 01-3 3zm0-13a1 1 0 00-1 1v1a1 1 0 002 0V3a1 1 0 00-1-1zm0 18a1 1 0 00-1 1v1a1 1 0 002 0v-1a1 1 0 00-1-1zm10-10h-1a1 1 0 000 2h1a1 1 0 000-2zM4 12H3a1 1 0 000 2h1a1 1 0 000-2zm14.05-7.05a1 1 0 10-1.414 1.414l.707.707a1 1 0 001.414-1.414zM7.05 18.05l-.707.707a1 1 0 001.414 1.414l.707-.707a1 1 0 00-1.414-1.414zm11.414 1.414a1 1 0 00-1.414-1.414l-.707.707a1 1 0 001.414 1.414zM7.05 5.95a1 1 0 101.414-1.414l-.707-.707a1 1 0 00-1.414 1.414z"
