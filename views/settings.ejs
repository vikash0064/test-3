<html>

<head>
  <title>Edit Profile - Blogs</title>
  <%- include('partials/common-styles') %>
    <style>
      .settings-container {
        background: #fff;
        border: 1px solid #dbdbdb;
        border-radius: 12px;
        padding: 40px;
        width: 100%;
        max-width: 600px;
        margin: 30px auto;
      }

      h2 {
        margin-top: 0;
        font-size: 24px;
        text-align: left;
        margin-bottom: 30px;
        color: #262626;
      }

      .form-group {
        display: grid;
        grid-template-columns: 120px 1fr;
        align-items: center;
        margin-bottom: 20px;
        gap: 20px;
      }

      label {
        font-weight: 600;
        font-size: 16px;
        color: #262626;
        text-align: right;
      }

      input[type="text"],
      input[type="email"],
      textarea {
        width: 100%;
        padding: 10px;
        border: 1px solid #dbdbdb;
        border-radius: 5px;
        font-size: 16px;
        background: #fafafa;
        box-sizing: border-box;
        transition: border-color 0.2s;
      }

      .avatar-section {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 30px;
      }

      .avatar-preview {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        object-fit: cover;
      }

      .avatar-info {
        display: flex;
        flex-direction: column;
      }

      .avatar-info b {
        font-size: 16px;
      }

      .change-photo-btn {
        color: #0095f6;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        padding: 0;
        background: none;
        border: none;
      }

      .submit-btn {
        background-color: #0095f6;
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 5px;
        font-weight: 600;
        cursor: pointer;
        font-size: 14px;
        margin-top: 10px;
        margin-left: 140px;
      }

      @media (max-width: 768px) {
        .settings-container {
          padding: 20px;
          border: none;
          margin: 0;
          background: none;
        }

        .form-group {
          grid-template-columns: 1fr;
          gap: 5px;
        }

        label {
          text-align: left;
        }

        .submit-btn {
          margin-left: 0;
          width: 100%;
        }

        .avatar-section {
          padding-left: 0;
        }
      }

      /* Dark Mode Updates */
      body.dark-mode .settings-container {
        background-color: #121212 !important;
        border-color: #333 !important;
      }

      body.dark-mode h2,
      body.dark-mode label,
      body.dark-mode .avatar-info b {
        color: #fff !important;
      }

      body.dark-mode input,
      body.dark-mode textarea {
        background: #000 !important;
        border-color: #333 !important;
        color: #fff !important;
      }
    </style>
</head>

<body>
  <%- include('partials/sidebar') %>
    <%- include('partials/modal') %>
      <%- include('partials/mobile-nav') %>

        <div class="main-content">
          <%- include('partials/top-nav') %>

            <div class="settings-container">
              <h2>Edit Profile</h2>

              <form method="POST" action="/settings" enctype="multipart/form-data">

                <div class="avatar-section">
                  <% if (user.avatar) { %>
                    <img src="<%= user.avatar %>" class="avatar-preview" id="previewImg">
                    <% } else { %>
                      <div style="width: 48px; height: 48px; border-radius: 50%; background: #efefef;"
                        class="avatar-preview"></div>
                      <% } %>
                        <div class="avatar-info">
                          <b>
                            <%= user.username %>
                          </b>
                          <label for="avatarInput" class="change-photo-btn">Change profile photo</label>
                          <input type="file" id="avatarInput" name="avatar" accept="image/*" style="display: none;"
                            onchange="previewFile()">
                        </div>
                </div>

                <div class="form-group">
                  <label>Name</label>
                  <input type="text" name="name" value="<%= user.name || '' %>" placeholder="Full Name">
                </div>

                <div class="form-group">
                  <label>Username</label>
                  <input type="text" name="username" value="<%= user.username %>" required>
                </div>

                <div class="form-group">
                  <label>Bio</label>
                  <textarea name="bio" rows="3" placeholder="Bio..."><%= user.bio || '' %></textarea>
                </div>

                <div class="form-group">
                  <label>Email</label>
                  <input type="email" name="email" value="<%= user.email %>" required>
                </div>

                <button type="submit" class="submit-btn">Submit Changes</button>
              </form>
            </div>
        </div>

        <script>
          function previewFile() {
            const preview = document.getElementById('previewImg');
            const file = document.querySelector('input[type=file]').files[0];
            const reader = new FileReader();

            reader.onloadend = function () {
              if (preview) {
                preview.src = reader.result;
              }
            }

            if (file) {
              reader.readAsDataURL(file);
            }
          }
        </script>
        <%- include('partials/scripts') %>
</body>

</html>