<html>

<head>
  <title>
    <%= user.username %> (@<%= user.username %>) • Blogs
  </title>
  <%- include('partials/common-styles') %>
    <style>
      .profile-container {
        max-width: 935px;
        margin: 30px auto;
        padding: 0 20px;
      }

      .profile-header {
        display: flex;
        margin-bottom: 44px;
        align-items: flex-start;
      }

      .avatar-container {
        flex: 1;
        display: flex;
        justify-content: center;
        margin-right: 30px;
      }

      .avatar-container img {
        width: 150px;
        height: 150px;
        border-radius: 50%;
        border: 1px solid #dbdbdb;
        padding: 2px;
        object-fit: cover;
      }

      .profile-info {
        flex: 2;
      }

      .profile-top {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 20px;
      }

      .profile-username {
        font-size: 28px;
        font-weight: 300;
        margin: 0;
      }

      .edit-profile-btn {
        text-decoration: none;
        color: #262626;
        border: 1px solid #dbdbdb;
        padding: 5px 9px;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 600;
      }

      .profile-stats {
        display: flex;
        gap: 40px;
        margin-bottom: 20px;
        list-style: none;
        padding: 0;
      }

      .profile-stats li {
        font-size: 16px;
      }

      .profile-stats b {
        font-weight: 600;
      }

      .profile-bio {
        font-size: 16px;
        line-height: 24px;
      }

      .profile-name {
        font-weight: 600;
        display: block;
      }

      .posts-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 28px;
        border-top: 1px solid #dbdbdb;
        padding-top: 50px;
      }

      .grid-item {
        position: relative;
        aspect-ratio: 1 / 1;
        overflow: hidden;
        background: #efefef;
      }

      .grid-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: opacity 0.3s;
      }

      .grid-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.3);
        display: flex;
        justify-content: center;
        align-items: center;
        opacity: 0;
        transition: opacity 0.3s;
        color: white;
        font-weight: bold;
        font-size: 18px;
      }

      .grid-item:hover .grid-overlay {
        opacity: 1;
      }

      .grid-item:hover img {
        opacity: 0.8;
      }

      @media (max-width: 768px) {
        .profile-header {
          flex-direction: row;
          /* Keep row but smaller */
          align-items: center;
          margin-bottom: 20px;
        }

        .avatar-container {
          margin-right: 20px;
          flex: none;
        }

        .avatar-container img {
          width: 77px;
          height: 77px;
        }

        .profile-top {
          flex-direction: column;
          align-items: flex-start;
          gap: 10px;
          margin-bottom: 10px;
        }

        .profile-username {
          font-size: 20px;
        }

        .profile-stats {
          display: flex;
          justify-content: space-around;
          width: 100vw;
          margin-left: -20px;
          border-top: 1px solid #dbdbdb;
          border-bottom: 1px solid #dbdbdb;
          padding: 10px 0;
          gap: 0;
        }

        .profile-stats li {
          text-align: center;
          font-size: 14px;
          color: #8e8e8e;
          display: flex;
          flex-direction: column;
        }

        .profile-stats b {
          color: #262626;
        }

        body.dark-mode .profile-stats b {
          color: #fff;
        }

        .posts-grid {
          grid-template-columns: repeat(3, 1fr);
          gap: 3px;
          padding-top: 10px;
        }
      }

      /* Dark Mode Updates */
      body.dark-mode .edit-profile-btn {
        background-color: #121212 !important;
        border-color: #333 !important;
        color: #e0e0e0 !important;
      }

      body.dark-mode .profile-username {
        color: #fff !important;
      }

      body.dark-mode .posts-grid,
      body.dark-mode .profile-stats {
        border-top-color: #333 !important;
        border-bottom-color: #333 !important;
      }
    </style>
</head>

<body>
  <%- include('partials/sidebar') %>
    <%- include('partials/modal') %>
      <%- include('partials/mobile-nav') %>

        <div class="main-content">
          <%- include('partials/top-nav') %>

            <div class="profile-container">
              <div class="profile-header">
                <div class="avatar-container">
                  <% if (user.avatar) { %>
                    <img src="<%= user.avatar %>" alt="profile photo">
                    <% } else { %>
                      <div style="width: 150px; height: 150px; border-radius: 50%; background: #efefef;"></div>
                      <% } %>
                </div>

                <div class="profile-info">
                  <div class="profile-top">
                    <h2 class="profile-username">
                      <%= user.username %>
                    </h2>
                    <a href="/settings" class="edit-profile-btn">Edit Profile</a>
                  </div>

                  <ul class="profile-stats hide-mobile">
                    <li><b>
                        <%= posts.length %>
                      </b> posts</li>
                    <li><b>0</b> followers</li>
                    <li><b>0</b> following</li>
                  </ul>

                  <div class="profile-bio">
                    <span class="profile-name">
                      <%= user.name || user.username %>
                    </span>
                    <p style="margin: 5px 0; white-space: pre-line;">
                      <%= user.bio || 'No bio yet.' %>
                    </p>
                    <span style="color: #8e8e8e; font-size: 12px;">Email: <%= user.email %></span>
                  </div>
                </div>
              </div>

              <!-- Mobile Stats -->
              <ul class="profile-stats show-mobile" style="display: none;">
                <li><b>
                    <%= posts.length %>
                  </b> <span>posts</span></li>
                <li><b>0</b> <span>followers</span></li>
                <li><b>0</b> <span>following</span></li>
              </ul>
              <style>
                @media (max-width: 768px) {
                  .hide-mobile {
                    display: none !important;
                  }

                  .show-mobile {
                    display: flex !important;
                  }
                }
              </style>

              <div class="posts-grid">
                <% posts.forEach(post=> { %>
                  <a href="/post/<%= post._id %>" class="grid-item">
                    <img src="<%= post.image %>" alt="post image">
                    <div class="grid-overlay">
                      <span>❤️ <%= post.likes.length %> 💬 <%= post.comments.length %></span>
                    </div>
                  </a>
                  <% }) %>
              </div>
            </div>
        </div>
        <%- include('partials/scripts') %>
</body>

</html>