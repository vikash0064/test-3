<html>

<head>
  <title>Register - Blogs</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      background-color: #fafafa;
      margin: 0;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    .register-container {
      background: #fff;
      border: 1px solid #dbdbdb;
      padding: 40px;
      width: 100%;
      max-width: 350px;
      text-align: center;
      box-sizing: border-box;
    }

    h2 {
      font-family: 'Billabong', cursive;
      font-size: 40px;
      margin-bottom: 20px;
    }

    p.msg {
      color: #8e8e8e;
      font-weight: 600;
      font-size: 17px;
      margin-bottom: 20px;
    }

    form {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    input {
      padding: 10px;
      border: 1px solid #dbdbdb;
      border-radius: 3px;
      background: #fafafa;
      font-size: 12px;
    }

    .avatar-label {
      font-size: 12px;
      color: #8e8e8e;
      text-align: left;
      margin-top: 5px;
    }

    button {
      background-color: #0095f6;
      color: white;
      border: none;
      padding: 8px;
      border-radius: 4px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 10px;
    }

    .error {
      color: #ed4956;
      font-size: 14px;
      margin-bottom: 20px;
    }

    .login-box {
      background: #fff;
      border: 1px solid #dbdbdb;
      padding: 20px;
      width: 100%;
      max-width: 350px;
      text-align: center;
      margin-top: 10px;
      box-sizing: border-box;
      font-size: 14px;
    }

    .login-box a {
      color: #0095f6;
      text-decoration: none;
      font-weight: 600;
    }

    /* Dark Mode */
    body.dark-mode {
      background-color: #000;
    }

    body.dark-mode .register-container,
    body.dark-mode .login-box {
      background-color: #121212;
      border-color: #333;
      color: #fff;
    }

    body.dark-mode input {
      background: #121212;
      border-color: #333;
      color: #fff;
    }
  </style>
</head>

<body>
  <div>
    <div class="register-container">
      <h2>Blogs</h2>
      <p class="msg">Sign up to see photos and videos from your friends.</p>
      <% if (error && error.length) { %>
        <p class="error">
          <%= error %>
        </p>
        <% } %>
          <form method="POST" action="/register" enctype="multipart/form-data">
            <input type="text" name="username" placeholder="Username" required>
            <input type="email" name="email" placeholder="Email" required>
            <input type="password" name="password" placeholder="Password" required>
            <div class="avatar-label">Profile Picture (Optional)</div>
            <input type="file" name="avatar" accept="image/*">
            <button type="submit">Sign Up</button>
          </form>
    </div>
    <div class="login-box">
      Have an account? <a href="/login">Log in</a>
    </div>
  </div>

  <script>
    if (localStorage.getItem('theme') === 'dark') {
      document.body.classList.add('dark-mode');
    }
  </script>
</body>

</html>